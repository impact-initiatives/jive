# ── Azure Queue Configuration ──────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=CHANGE_THIS
JIVE_QUEUE_NAME=CHANGE_THIS
JIVE_API_KEY=CHANGE_THIS

# ── Jira Credentials ───────────────────────────────────────────
JIRA_BASE_URL=CHANGE_THIS
JIRA_API_EMAIL=CHANGE_THIS
JIRA_API_TOKEN=CHANGE_THIS

# ── IMPACT Repository Credentials (WordPress auth) ──────────────
# only needed if interacting with the impact repo.
REPO_USERNAME=CHANGE_THIS
REPO_PASSWORD=CHANGE_THIS

# ── ProForma Field Matching (Labels in Jira Form) ───────────────
PROFORMA_REPO_LABEL=IMPACT Repository
PROFORMA_DATASET_TYPE_LABEL=Dataset type

# ── Queue & Validation Custom Rules ─────────────────────────────
JIVE_MAX_RETRIES=3
JIVE_MAX_ATTACHMENT_MB=250

# ── Transition IDs (Jira Workflow States) ──────────────────────
JIRA_TRANSITION_APPROVED=11
JIRA_TRANSITION_REJECTED=21

# ── Secure Link & SSRF Protection ──────────────────────────────
SECURE_LINK_USERNAME=CHANGE_THIS
SECURE_LINK_PASSWORD=CHANGE_THIS
ALLOWED_DOMAINS=CHANGE_THIS,CHANGE_THIS

# ── Excel Report Configuration ─────────────────────────────────
MAX_EXCEL_ERRORS=50000

# ── Advanced Worker Configuration ──────────────────────────────
JIVE_FORCE_VALIDATION=false
REPO_SESSION_TTL_SECONDS=600

# Documentation urls
DATA_CLEANING_CHECKLIST = CHANGE_THIS
DATA_ANALYSIS_CHECKLIST = CHANGE_THIS
ARGUS_VALIDATION_RULES = CHANGE_THIS